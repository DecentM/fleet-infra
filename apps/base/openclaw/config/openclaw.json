        "!2LYaYf2c88-CZ5CmkCvF6z8ZhXmB3Oj06D3gEbb3fn0:borooka.ee"
      ],
      "dm": {
        "policy": "pairing"
      },
      "groups": {
        "!2LYaYf2c88-CZ5CmkCvF6z8ZhXmB3Oj06D3gEbb3fn0:borooka.ee": {
          "requireMention": false
        }
      }
    }
  },
