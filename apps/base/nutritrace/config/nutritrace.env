DB_PATH=/data/db/nutritrace.db
UPLOADS_PATH=/data/uploads
OFF_LOCAL_DB=/data/off-mirror/off.parquet
PORT=3001
LOG_LEVEL=info
OIDC_ISSUER=https://auth.borooka.ee
OIDC_CLIENT_ID=nutritrace
OIDC_DISPLAY_NAME=Authelia
OIDC_REDIRECT_URIS=https://nutritrace.cluster.arpa/api/auth/oidc/callback/1
OIDC_SCOPE=openid profile email
OIDC_TOKEN_AUTH_METHOD=client_secret_post
OIDC_AUTO_REGISTER=1
OIDC_AUTO_LINK=1
OIDC_IS_ACTIVE=1
AI_PROVIDER=oai-compat
AI_BASE_URL=https://openrouter.ai/api
AI_ENABLED=true
# AI_MODEL: OpenRouter model slug for the AI assistant. Must support BOTH vision
# (image_url) AND function calling/tool use. E.g. google/gemini-2.5-flash or
# anthropic/claude-3-5-haiku
AI_MODEL=openrouter/auto
SMTP_PORT=587
SMTP_SECURE=false
