# NutriTrack non-secret environment variables
# Secret values (B2 credentials, auth secret, OpenAI key) live in the
# SealedSecret (nutritrack-secrets). DB credentials come from the
# CNPG-generated secret (nutritrack-db-app).

BETTER_AUTH_URL=https://nutritrack.cluster.arpa
NEXT_PUBLIC_APP_URL=https://nutritrack.cluster.arpa

# B2 S3-compatible storage — endpoint/bucket/keys are in the sealed secret
MINIO_PORT=443
MINIO_USE_SSL=true

REDIS_URL=redis://nutritrack-redis.app-nutritrack.svc.cluster.local:6379

VISION_PROVIDER=openai
